# Copy to .env and adjust. Paths are relative to the backend/ directory when running uvicorn from backend/.

# SQLite (default local demo)
DATABASE_URL=sqlite:///./community_portal.db

# PostgreSQL (production / team demo) — create DB `community_portal` first
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/community_portal

AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
GRAPH_SENDER_EMAIL=
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
DEV_MODE=true
